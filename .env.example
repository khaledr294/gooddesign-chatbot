# ============================================
# Good Design Chatbot - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ── Database ──────────────────────────────────
DB_PASSWORD=changeme
DATABASE_URL=postgresql://gd_user:changeme@localhost:5432/gooddesign

# ── Redis ─────────────────────────────────────
REDIS_PASSWORD=changeme
REDIS_URL=redis://:changeme@localhost:6379

# ── JWT ───────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-here

# ── WhatsApp (Meta Cloud API) ─────────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=your-webhook-verify-token

# ── Salla API ─────────────────────────────────
SALLA_API_URL=https://api.salla.dev/admin/v2
SALLA_ACCESS_TOKEN=
SALLA_REFRESH_TOKEN=
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_WEBHOOK_SECRET=

# ── S3 Storage ────────────────────────────────
S3_BUCKET=gooddesign-uploads
S3_REGION=me-south-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ── Dashboard ─────────────────────────────────
DASHBOARD_API_URL=http://localhost:3000/api/admin
DASHBOARD_SOCKET_URL=http://localhost:3000
