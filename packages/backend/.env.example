# Backend Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/gooddesign_chatbot"

# Redis
REDIS_URL="redis://localhost:6379"

# WhatsApp Cloud API
WHATSAPP_TOKEN="your_whatsapp_token"
WHATSAPP_PHONE_NUMBER_ID="your_phone_number_id"
WHATSAPP_BUSINESS_ACCOUNT_ID="your_business_account_id"
WHATSAPP_VERIFY_TOKEN="your_webhook_verify_token"

# Salla API
SALLA_CLIENT_ID="your_salla_client_id"
SALLA_CLIENT_SECRET="your_salla_client_secret"
SALLA_ACCESS_TOKEN="your_salla_access_token"
SALLA_REFRESH_TOKEN="your_salla_refresh_token"
SALLA_WEBHOOK_SECRET="your_salla_webhook_secret"

# S3 Storage
S3_ENDPOINT="https://your-bucket.s3.amazonaws.com"
S3_REGION="me-south-1"
S3_BUCKET="gooddesign-chatbot"
S3_ACCESS_KEY="your_access_key"
S3_SECRET_KEY="your_secret_key"

# App
PORT=3000
HOST="0.0.0.0"
NODE_ENV="development"
CORS_ORIGIN="http://localhost:3001"
JWT_SECRET="your_jwt_secret_min_32_chars_long"

# Admin Dashboard URL
DASHBOARD_URL="http://localhost:3001"
